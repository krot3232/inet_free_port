{erl_opts, [debug_info]}.
{deps, []}.
{ex_doc, [
    {extras, ["README.md", "LICENSE"]},
    {main, "README.md"},
    {source_url, "https://github.com/krot3232/inet_free_port"},
    {api_reference, true},
    {prefix_ref_vsn_with_v, false}
]}.
{plugins, [rebar3_hex]}.
{hex, [
    {doc, #{provider => ex_doc}}
]}.

{project_plugins, [
    rebar3_ex_doc,
    rebar3_hex
]}.
